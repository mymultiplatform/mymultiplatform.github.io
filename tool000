<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Text Cleaner</title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Times New Roman", Times, serif;
      background: #f4f4f4;
      color: #111;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }

    main {
      width: 100%;
      max-width: 800px;
      background: #fff;
      border: 1px solid #ccc;
      padding: 24px;
    }

    h1,
    h2 {
      margin: 0 0 16px;
      font-weight: normal;
    }

    h1 {
      font-size: 34px;
      text-align: center;
    }

    h2 {
      font-size: 24px;
      margin-top: 24px;
    }

    textarea,
    .output {
      width: 100%;
      min-height: 180px;
      border: 1px solid #999;
      padding: 12px;
      font-family: "Times New Roman", Times, serif;
      font-size: 20px;
      line-height: 1.4;
      background: #fff;
      color: #111;
    }

    textarea {
      resize: vertical;
      outline: none;
    }

    .output {
      white-space: pre-wrap;
      word-wrap: break-word;
      overflow-y: auto;
    }

    .buttons {
      display: flex;
      gap: 10px;
      margin-top: 12px;
    }

    button {
      font-family: "Times New Roman", Times, serif;
      font-size: 18px;
      padding: 8px 16px;
      border: 1px solid #777;
      background: #eee;
      cursor: pointer;
    }

    button:hover {
      background: #ddd;
    }

    @media (max-width: 600px) {
      main {
        padding: 16px;
      }

      h1 {
        font-size: 28px;
      }

      h2 {
        font-size: 22px;
      }

      textarea,
      .output,
      button {
        font-size: 18px;
      }

      .buttons {
        flex-direction: column;
      }
    }
  </style>
</head>

<body>
  <main>
    <h1>Text Cleaner</h1>

    <textarea id="inputText" placeholder="Paste text here"></textarea>

    <div class="buttons">
      <button id="clearButton">Clear</button>
      <button id="copyButton">Copy</button>
    </div>

    <h2>Cleaned Text</h2>

    <div id="outputText" class="output"></div>
  </main>

  <script>
    const inputText = document.getElementById("inputText");
    const outputText = document.getElementById("outputText");
    const clearButton = document.getElementById("clearButton");
    const copyButton = document.getElementById("copyButton");

    function cleanText(text) {
      let cleaned = "";

      for (let i = 0; i < text.length; i++) {
        const char = text[i];

        if (
          (char >= "A" && char <= "Z") ||
          (char >= "a" && char <= "z") ||
          char === "." ||
          char === " " ||
          char === "\n" ||
          char === "\r" ||
          char === "\t"
        ) {
          cleaned += char;
        }
      }

      return cleaned;
    }

    inputText.addEventListener("input", function () {
      outputText.textContent = cleanText(inputText.value);
    });

    clearButton.addEventListener("click", function () {
      inputText.value = "";
      outputText.textContent = "";
      inputText.focus();
    });

    copyButton.addEventListener("click", async function () {
      const text = outputText.textContent;

      if (!text.trim()) {
        copyButton.textContent = "Nothing";
        setTimeout(function () {
          copyButton.textContent = "Copy";
        }, 1000);
        return;
      }

      try {
        await navigator.clipboard.writeText(text);
        copyButton.textContent = "Copied";
        setTimeout(function () {
          copyButton.textContent = "Copy";
        }, 1000);
      } catch (error) {
        copyButton.textContent = "Error";
        setTimeout(function () {
          copyButton.textContent = "Copy";
        }, 1000);
      }
    });
  </script>
</body>
</html>
